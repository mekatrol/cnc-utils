{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Mekatrol PCBCAM",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "program": "${workspaceFolder}/main.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "MEKATROL_PCBCAM_DEBUG_SPLASH": "0"
      }
    },
    {
      "name": "Mekatrol PCBCAM: Sample NC",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "program": "${workspaceFolder}/main.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": ["/home/dad/repos/cnc-utils/gerber2nc/nc/test_edge_cut.nc"],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    }
  ]
}
